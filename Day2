print("A poultry farm has group of hens and cows together we need to find no of hens and cows seperately if total no of legs and heads are given")
legs=int(input("enter legs:"))
heads=int(input("enter heads:"))
flag=False
for cows in range(heads+1):
    hens=heads-cows
    cal_legs=cows*4+hens*2
    if cal_legs==legs:
        flag=True
        break
if flag:
    print("cows",cows)
    print("hens",hens)
else:
    print("no solution")

